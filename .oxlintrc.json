{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "react-perf", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "warn",
    "style": "warn"
  },
  "ignorePatterns": [".gadget/**", ".react-router/**", "web/components/ui/**"],
  "options": {
    "maxWarnings": 0,
    "typeAware": true,
    "typeCheck": true
  },
  "rules": {
    "typescript/no-confusing-void-expression": ["warn", { "ignoreVoidReturningFunctions": true, "ignoreArrowShorthand": true }],
    "typescript/no-misused-promises": ["warn", { "checksVoidReturn": false }],
    "typescript/prefer-nullish-coalescing": ["warn", { "ignorePrimitives": { "string": true } }],
    "typescript/restrict-template-expressions": ["warn", { "allowNumber": true }],
    "react/react-in-jsx-scope": "off",
    "import/no-named-export": "off",
    "import/group-exports": "off",
    "func-style": "off",
    "react/jsx-max-depth": "off",
    "no-ternary": "off",
    "no-magic-numbers": "off",
    "id-length": "off",
    "react/jsx-props-no-spreading": "off",
    "import/prefer-default-export": "off",
    "import/exports-last": "off",
    "no-inline-comments": "off",
    "no-continue": "off",
    "react/jsx-handler-names": "off",
    "import/max-dependencies": "off",
    "max-lines": "off",
    "max-lines-per-function": "off",
    "max-statements": "off",
    "no-warning-comments": "off",
    "no-shadow": "off",
    "no-nested-ternary": "off",
    "init-declarations": "off",
    "import/no-unassigned-import": "off",
    "import/no-nodejs-modules": "off",
    "require-await": "off",
    "sort-keys": "off",
    "import/consistent-type-specifier-style": "off",
    "sort-imports": "off"
  }
}
